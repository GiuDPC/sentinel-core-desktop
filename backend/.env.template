# ═══════════════════════════════════════════════════════════════
# Sentinel-Core — Variables de Entorno
# Copia este archivo como .env y reemplaza los valores
# ═══════════════════════════════════════════════════════════════

# Base de datos PostgreSQL (ajustar usuario, contraseña, host y nombre)
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@localhost:5432/sentinel_core_dev?schema=public"

# Puerto del servidor Express
PORT=3000

# Entorno de ejecución (development | production | test)
NODE_ENV=development

# Secreto para firmar los JWT (mínimo 20 caracteres, CAMBIAR en producción)
JWT_SECRET="cambiar_este_secreto_en_produccion_min_20_chars"