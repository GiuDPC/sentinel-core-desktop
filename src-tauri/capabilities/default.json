{
  "identifier": "default",
  "description": "Default capabilities for Sentinel Core",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "notification:allow-is-permission-granted",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "dialog:allow-message",
    "dialog:allow-ask"
  ]
}