# ─── Sentinel Core Desktop .gitignore ───

# Archivos sensibles y personales
Prompt.md
.env
.env.local
*.session.sqlite
error.md

# Rust / Tauri build artifacts
src-tauri/target/
src-tauri/.cargo/

# Frontend build output (Vite)
frontend/dist/

# Dependencias
node_modules/

# Prisma generated (legacy web reference)
generated/

# Tauri generated schemas
src-tauri/gen/

# Mobile assets (desktop-only app)
src-tauri/icons/android/
src-tauri/icons/ios/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
